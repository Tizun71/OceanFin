# ─────────────────────────────────────────────────────────────
# OceanFin Frontend (Next.js) — env example
# NEXT_PUBLIC_* are exposed to the browser. Never put secrets here.
# ─────────────────────────────────────────────────────────────

# --- Core ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SITE_URL="https://oceanfin.app"

# --- Wallet (EVM multi-chain via wagmi + RainbowKit) ---
# WalletConnect Cloud project id (https://cloud.reown.com). Required for
# mobile / multi-wallet. If empty, only injected wallets (MetaMask) work.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- EVM RPC endpoints (client-side reads) ---
# Production: use a paid provider (Alchemy/Infura/QuickNode) — public RPC
# rate-limits break simulation/quotes. Public defaults shown as fallback.
NEXT_PUBLIC_AVALANCHE_RPC_URL="https://api.avax.network/ext/bc/C/rpc"
NEXT_PUBLIC_BASE_RPC_URL="https://mainnet.base.org"
NEXT_PUBLIC_ARBITRUM_RPC_URL="https://arb1.arbitrum.io/rpc"

# --- Cross-chain bridge (LI.FI) ---
# No API key needed for MVP. Integrator string identifies your app in routes.
NEXT_PUBLIC_LIFI_API_URL="https://li.quest/v1"
NEXT_PUBLIC_LIFI_INTEGRATOR="oceanfin"
