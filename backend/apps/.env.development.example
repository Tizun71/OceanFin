# ─────────────────────────────────────────────────────────────
# OceanFin Backend (NestJS) — DEVELOPMENT env example
# Backend is non-custodial: simulates only, never holds user keys.
# ─────────────────────────────────────────────────────────────

# --- Core ---
NODE_ENV=development
PORT=3001

# --- Database (Postgres) ---
# Matches docker-compose.yml. Run: docker compose up -d
DATABASE_URL="postgresql://oceanfin:oceanfin@localhost:5432/oceanfin"
# Set to 'true' for managed Postgres that requires SSL (Neon/RDS/...).
DATABASE_SSL=false

# --- AI (Google Gemini) ---
GEMINI_API_KEY=

# --- Polkadot / Hydration ---
HYDRATION_RPC_ENDPOINT="wss://rpc.hydradx.cloud"

# --- EVM RPC endpoints (server-side simulation reads) ---
AVALANCHE_RPC_URL="https://api.avax.network/ext/bc/C/rpc"
BASE_RPC_URL="https://mainnet.base.org"
ARBITRUM_RPC_URL="https://arb1.arbitrum.io/rpc"

# --- Cross-chain bridge (LI.FI) ---
LIFI_API_URL="https://li.quest/v1"
LIFI_API_KEY=
