# ─────────────────────────────────────────────────────────────
# OceanFin Backend (NestJS) — PRODUCTION env example
# Secrets — do NOT commit real values. Backend NEVER holds user keys
# (non-custodial): it simulates only, client signs.
# ─────────────────────────────────────────────────────────────

# --- Core ---
NODE_ENV=production
PORT=3001

# --- Database (Postgres) ---
DATABASE_URL="postgresql://user:password@host:5432/oceanfin"
# Set to 'true' for managed Postgres that requires SSL (Neon/RDS/...).
DATABASE_SSL=true

# --- AI (Google Gemini) ---
GEMINI_API_KEY=

# --- Polkadot / Hydration ---
HYDRATION_RPC_ENDPOINT="wss://rpc.hydradx.cloud"

# --- EVM RPC endpoints (server-side simulation reads) ---
# Production: use a paid provider (Alchemy/Infura/QuickNode). Public RPC
# rate-limits will break simulateContract / quote calls under load.
AVALANCHE_RPC_URL="https://api.avax.network/ext/bc/C/rpc"
BASE_RPC_URL="https://mainnet.base.org"
ARBITRUM_RPC_URL="https://arb1.arbitrum.io/rpc"

# --- Cross-chain bridge (LI.FI) ---
# MVP works keyless. Set an API key for higher rate limits in production.
LIFI_API_URL="https://li.quest/v1"
LIFI_API_KEY=
